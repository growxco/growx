# ===========================================================================
# Grow-X — Variáveis de ambiente (copie pra .env.local e preencha)
# Todas opcionais: a aplicação roda sem nenhuma. Cada variável que faltar
# desliga apenas a integração correspondente (sem quebrar build).
# ===========================================================================

# ============== SERVER-SIDE (Vercel Functions /api/*) ==============
# NUNCA prefixar com VITE_ — essas keys vão pro browser e ficam expostas

# OpenAI API key — usada como fallback ou pra tasks específicas (gpt-4o-mini)
# Console: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — usada como modelo principal (Flash é grátis até cota generosa)
# Console: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelos default — pode trocar sem redeploy
AI_CHAT_MODEL=gemini-1.5-flash-latest
AI_FALLBACK_MODEL=gpt-4o-mini

# Rate limiting (defesa contra abuso)
AI_RATE_LIMIT_PER_MINUTE=20
AI_RATE_LIMIT_PER_DAY=200

# ============== CLIENT-SIDE (vão pro bundle do browser) ==============
# Prefixo VITE_ obrigatório. Tudo aqui é PÚBLICO — não use segredos.

# Analytics
VITE_GA_ID=                   # GA4 (G-XXXXXXX) → analytics.google.com
VITE_META_PIXEL_ID=            # Meta Pixel → business.facebook.com/events_manager
VITE_LINKEDIN_PARTNER_ID=      # LinkedIn Insight → linkedin.com/campaignmanager
VITE_CLARITY_ID=               # Microsoft Clarity → clarity.microsoft.com

# CRM / Forms
VITE_CRM_WEBHOOK_URL=          # Endpoint HTTPS POST JSON (HubSpot/Brevo/n8n/Make/Zapier)
VITE_FORMSUBMIT_EMAIL=growx@growx.com.br  # Fallback sem backend
VITE_CALENDLY_URL=             # https://calendly.com/growx/demo

# Site
VITE_SITE_URL=https://www.growx.com.br

# Feature flags
VITE_AI_ASSISTANT_ENABLED=true # Liga o widget AI no Header (precisa ter GEMINI_API_KEY ou OPENAI_API_KEY no servidor)
